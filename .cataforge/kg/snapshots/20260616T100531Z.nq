<https://cataforge.dev/instance/API-013> <https://cataforge.dev/ontology/belongs_to_project> <https://cataforge.dev/instance/proj-default> .
<https://cataforge.dev/instance/API-013> <https://cataforge.dev/ontology/narrative_body> "```yaml\ntool: apply_zh_typo\nmodule: M-009\nmaps_to: F-013 AC-002 / F-014 (AC-005)\nrequest:\n  body:\n    markdown: { type: string, required: true }\n    rules: { type: \"('zh-en-space'|'punctuation'|'quotes'|'ellipsis-dash')[]\", required: false, desc: \"缺省 4 类全启\" }\nresponse:\n  schema:\n    fixed: { type: string, desc: \"修订后的 Markdown\" }\n    perRule: { type: \"Record<string, number>\", desc: \"每类规则命中次数\" }\n    totalChanges: { type: number }\n```" .

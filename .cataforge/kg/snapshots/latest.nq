<https://cataforge.dev/instance/doc/arch/sec/4.1%20%E5%AE%9E%E4%BD%93%E5%85%B3%E7%B3%BB> <https://cataforge.dev/ontology/content_hash> "5c9d916b3b31bd6fb9d714482c59fd73f273e3e5a31789d044fe23999700bd2c" .
<https://cataforge.dev/instance/doc/arch/sec/4.1%20%E5%AE%9E%E4%BD%93%E5%85%B3%E7%B3%BB> <https://cataforge.dev/ontology/position> "000001" .
<https://cataforge.dev/instance/doc/arch/sec/4.1%20%E5%AE%9E%E4%BD%93%E5%85%B3%E7%B3%BB> <https://cataforge.dev/ontology/narrative_body> "### 4.1 实体关系\n\n```mermaid\nerDiagram\n    Document ||--o{ UploadRecord : \"引用图片\"\n    Document }o--|| Theme : \"frontmatter.theme\"\n    Document ||--o{ YDocSnapshot : \"Yjs 同步快照\"\n    Theme ||--o{ Pack : \"继承自 / 安装自\"\n    Theme ||--o{ TemplateDefinition : \"命名空间下注册\"\n    Pack }o--o{ RulesetVersion : \"可声明规则补丁\"\n    Job ||--o{ UploadRecord : \"上传任务产出\"\n    Job }o--|| Credential : \"运行时使用凭据\"\n    Job }o--|| ApiKey : \"提交方\"\n    DiagnosticReport }o--|| Document : \"为 Document 生成\"\n    Credential }o--|| ApiKey : \"调用方持有 ApiKey\"\n    YDocSnapshot }o--|| ApiKey : \"归属\"\n\n    Document {\n      string id PK\n      string title\n      string markdownSource\n      object frontmatter\n      string activeThemeId\n      datetime createdAt\n      datetime updatedAt\n      datetime lastBackupAt\n    }\n    Theme {\n      string id PK\n      string name\n      string version\n      string scene\n      object tokens\n      object paintable\n      object assets\n      object templates\n      string parentThemeId\n    }\n    Pack {\n      string id PK\n      string name\n      string version\n      object manifest\n      object schemas\n      array variants\n      array rulePatches\n    }\n    RulesetVersion {\n      string version PK\n      number ruleCount\n      string schemaVersion\n      array rules\n    }\n    Job {\n      string jobId PK\n      string state\n      string kind\n      string idempotencyKey\n      object inputDigest\n      object result\n      object error\n      number progress\n      datetime createdAt\n      datetime updatedAt\n    }\n    Credential {\n      string id PK\n      string kind\n      string scope\n      string storageRef\n      datetime createdAt\n      datetime rotatedAt\n    }\n    UploadRecord {\n      string id PK\n      string source\n      string targetHost\n      string remoteUrl\n      number sizeBytes\n      string sha256\n      datetime uploadedAt\n    }\n    DiagnosticReport {\n      string id PK\n      string documentId\n      string versionTriple\n      array diagnostics\n      array nodeDiffs\n      array nodeChangeRecords\n      array nightRiskIssues\n      datetime generatedAt\n    }\n    ApiKey {\n      string id PK\n      string keyHash\n      string ownerRef\n      string scope\n      object quotaConfig\n      datetime createdAt\n      datetime revokedAt\n    }\n    YDocSnapshot {\n      string snapshotId PK\n      string docId\n      blob updatePayload\n      number opsCount\n      number sizeBytes\n      string apiKeyId\n      datetime createdAt\n    }\n    TemplateDefinition {\n      string id PK\n      string themeId PK\n      string markdown\n      object metadata\n    }\n```" .

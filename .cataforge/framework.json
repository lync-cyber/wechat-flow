{
  "version": "0.5.0",
  "runtime_api_version": "1.0",
  "runtime": {
    "platform": "claude-code"
  },
  "description": "CataForge 统一框架配置。version 字段在 cataforge setup / upgrade apply 写盘时由 scaffold._stamp_framework_version 戳入实际包版本（cataforge.__version__）。upgrade apply 的 preserve 字段：runtime.platform、upgrade.state；其余字段（version、constants、features、migration_checks、upgrade.source 与 description 自身）均被最新 scaffold 全量覆盖。详见 docs/reference/configuration.md §framework.json。",
  "upgrade": {
    "source": {
      "type": "github",
      "repo": "lync-cyber/CataForge",
      "branch": "main",
      "token_env": "GITHUB_TOKEN"
    },
    "state": {
      "last_commit": "",
      "last_version": "",
      "last_upgrade_date": ""
    }
  },
  "feedback": {
    "gh": {
      "labels": {
        "bug": [
          "bug"
        ],
        "suggest": [
          "enhancement"
        ],
        "correction-export": [
          "enhancement"
        ]
      },
      "fallback_on_missing_label": true
    }
  },
  "kg": {
    "kg_active_doc_types": [
      "prd",
      "arch",
      "test"
    ],
    "store_backend": "oxigraph",
    "db_path": ".cataforge/kg/store",
    "ontology_namespace": "https://cataforge.dev/kg/",
    "base_namespace": "https://cataforge.dev/kg/instances/"
  },
  "claude_md_limits": {
    "max_bytes": 30000,
    "max_state_section_lines": 80,
    "learnings_registry_max_entries": 10
  },
  "constants": {
    "MAX_QUESTIONS_PER_BATCH": 3,
    "MANUAL_REVIEW_CHECKPOINTS": [
      "pre_dev",
      "post_sprint",
      "pre_deploy"
    ],
    "EVENT_LOG_PATH": "docs/EVENT-LOG.jsonl",
    "EVENT_LOG_SCHEMA": ".cataforge/schemas/event-log.schema.json",
    "DOC_SPLIT_THRESHOLD_LINES": 300,
    "META_DOC_SPLIT_THRESHOLD_LINES": 500,
    "DOC_REVIEW_L2_SKIP_THRESHOLD_LINES": 200,
    "DOC_REVIEW_L2_SKIP_DOC_TYPES": [
      "brief",
      "prd-lite",
      "arch-lite",
      "dev-plan-lite",
      "changelog"
    ],
    "TDD_LIGHT_LOC_THRESHOLD": 150,
    "TDD_DEFAULT_MODE": "light",
    "TDD_REFACTOR_TRIGGER": [
      "complexity",
      "duplication",
      "coupling"
    ],
    "SPRINT_REVIEW_MICRO_TASK_COUNT": 3,
    "CODE_REVIEW_L2_SKIP_TASK_KINDS": [
      "chore",
      "config",
      "docs"
    ],
    "CODE_REVIEW_L2_SKIP_LIGHT_MAX_AC": 2,
    "ADAPTIVE_REVIEW_DOWNGRADE_CLEAN_TASKS": 10,
    "RETRO_TRIGGER_SELF_CAUSED": 5,
    "EVENT_LOG_DRIFT_MIN_EVENTS": 10,
    "PRE_DEPLOY_DEMO_REQUIRED": null,
    "PRE_DEPLOY_DEMO_MIN_ACS": 1,
    "ANTI_PATTERN_MIN_COUNT_SKILL": 3,
    "ANTI_PATTERN_MIN_COUNT_AGENT": 4,
    "AGENT_MODEL_DEFAULTS": {
      "orchestrator": "inherit",
      "product-manager": "standard",
      "architect": "heavy",
      "ui-designer": "standard",
      "tech-lead": "standard",
      "implementer": "standard",
      "test-writer": "standard",
      "refactorer": "standard",
      "qa-engineer": "standard",
      "devops": "standard",
      "debugger": "heavy",
      "reviewer": "standard",
      "reflector": "light"
    },
    "AGENT_MODEL_TIER_HEAVY_WHITELIST": [
      "architect",
      "debugger"
    ],
    "SKILL_RUNNER_TIMEOUT_DEFAULT_SECS": 300
  },
  "dispatcher_skills": [
    "tdd-engine",
    "agent-dispatch",
    "start-orchestrator"
  ],
  "features": {
    "tdd-engine": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": "development",
      "description": "TDD三阶段开发引擎 (RED→GREEN→REFACTOR)"
    },
    "doc-review": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": null,
      "description": "文档双层审计 (Layer 1脚本 + Layer 2 AI)"
    },
    "code-review": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": "development",
      "description": "代码双层审计 (Layer 1 lint + Layer 2 AI)"
    },
    "penpot-sync": {
      "min_version": "0.1.0",
      "auto_enable": false,
      "phase_guard": "ui_design",
      "description": "Penpot设计工具集成 (需设置 design-tool: penpot)"
    },
    "sprint-review": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": "development",
      "description": "Sprint完成度审查 — 计划vs实际对比、AC覆盖验证、范围偏移检测"
    },
    "change-guard": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": null,
      "description": "变更守卫 — 分析变更请求与文档一致性，确保文档先行"
    },
    "correction-hook": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": null,
      "description": "On-Correction Learning 放宽 — hook 自动捕获 AskUserQuestion option-override 信号"
    },
    "framework-feedback": {
      "min_version": "0.3.0",
      "auto_enable": true,
      "phase_guard": null,
      "description": "下游对 CataForge 框架本体的反馈打包 — 聚合 doctor + EVENT-LOG + upstream-gap corrections，通过 cataforge feedback CLI 或 framework-feedback skill 发出"
    },
    "framework-issue-resolve": {
      "min_version": "0.4.0",
      "auto_enable": false,
      "phase_guard": null,
      "description": "上游 CataForge 维护者侧 — 全闭环消化 GitHub issue：拉取 → 审查分析 → 给修复意见 → 实施 → 关闭。覆盖 cataforge issue triage（草稿）+ cataforge issue close（模板化关闭）两步 CLI，3↔4 步是人工 go/no-go。"
    },
    "claude-md-hygiene": {
      "min_version": "0.4.0",
      "auto_enable": true,
      "phase_guard": null,
      "description": "CLAUDE.md 卫生 — Learnings Registry 条目数上限 + claude_md_size doctor 检查；超限时给出 cataforge claude-md compact 提示"
    }
  },
  "migration_checks": [
    {
      "id": "mc-0.1.0-constants",
      "release_version": "0.1.0",
      "deprecate_after": "0.2.0",
      "description": "COMMON-RULES.md 必须定义执行模式矩阵引用的配置常量",
      "type": "file_must_contain",
      "path": ".cataforge/rules/COMMON-RULES.md",
      "patterns": [
        "DOC_SPLIT_THRESHOLD_LINES",
        "DOC_REVIEW_L2_SKIP_THRESHOLD_LINES",
        "DOC_REVIEW_L2_SKIP_DOC_TYPES",
        "TDD_LIGHT_LOC_THRESHOLD",
        "TDD_DEFAULT_MODE",
        "TDD_REFACTOR_TRIGGER",
        "SPRINT_REVIEW_MICRO_TASK_COUNT",
        "CODE_REVIEW_L2_SKIP_TASK_KINDS",
        "ADAPTIVE_REVIEW_DOWNGRADE_CLEAN_TASKS",
        "RETRO_TRIGGER_SELF_CAUSED"
      ]
    },
    {
      "id": "mc-0.2.0-tdd-light-default",
      "release_version": "0.2.0",
      "description": "TDD_LIGHT_LOC_THRESHOLD 提升至 150 且默认模式翻转为 light，配套 TDD_DEFAULT_MODE / TDD_REFACTOR_TRIGGER 等新常量；旧值 50/standard-default 已废弃",
      "type": "file_must_contain",
      "path": ".cataforge/rules/COMMON-RULES.md",
      "patterns": [
        "TDD_LIGHT_LOC_THRESHOLD | 150",
        "TDD_DEFAULT_MODE | light",
        "SPRINT_REVIEW_MICRO_TASK_COUNT | 3"
      ]
    },
    {
      "id": "mc-0.2.0-model-tier-migration",
      "release_version": "0.2.0",
      "description": "AGENT.md 必须使用 model_tier (light/standard/heavy/inherit/none) 取代 legacy model 字面量。translator 在 deploy 时丢弃 legacy `model:` 行（无过渡期）；framework-review B7-β FAIL 阻拦升级残留",
      "type": "file_must_contain",
      "path": ".cataforge/framework.json",
      "patterns": [
        "AGENT_MODEL_DEFAULTS",
        "AGENT_MODEL_TIER_HEAVY_WHITELIST",
        "EVENT_LOG_DRIFT_MIN_EVENTS"
      ]
    },
    {
      "id": "mc-0.2.0-dispatcher-skills",
      "release_version": "0.2.0",
      "description": "framework.json 顶层必须声明 dispatcher_skills，B5-α 据此区分 skill-as-router 与未定义 agent；endswith('-engine') 命名硬编码已删除",
      "type": "file_must_contain",
      "path": ".cataforge/framework.json",
      "patterns": [
        "dispatcher_skills"
      ]
    },
    {
      "id": "mc-0.1.0-no-legacy-constant",
      "release_version": "0.1.0",
      "deprecate_after": "0.2.0",
      "description": "MIN_REVIEW_SOURCES 已被 RETRO_TRIGGER_SELF_CAUSED 取代",
      "type": "file_must_not_contain",
      "path": ".cataforge/rules/COMMON-RULES.md",
      "patterns": [
        "MIN_REVIEW_SOURCES"
      ]
    },
    {
      "id": "mc-0.1.0-lite-templates",
      "release_version": "0.1.0",
      "deprecate_after": "0.2.0",
      "description": "agile-lite / agile-prototype 模式所需模板齐全",
      "type": "dir_must_contain_files",
      "path": ".cataforge/skills/doc-gen/templates",
      "patterns": [
        "prototype/brief.md",
        "lite/prd-lite.md",
        "lite/arch-lite.md",
        "lite/dev-plan-lite.md"
      ]
    },
    {
      "id": "mc-0.1.0-docgen-constant-ref",
      "release_version": "0.1.0",
      "deprecate_after": "0.2.0",
      "description": "doc-gen SKILL.md 必须引用 DOC_SPLIT_THRESHOLD_LINES 而非硬编码 '500 行'",
      "type": "file_must_contain",
      "path": ".cataforge/skills/doc-gen/SKILL.md",
      "patterns": [
        "DOC_SPLIT_THRESHOLD_LINES"
      ]
    },
    {
      "id": "mc-0.1.0-docgen-no-hardcoded-500",
      "release_version": "0.1.0",
      "deprecate_after": "0.2.0",
      "description": "doc-gen SKILL.md 不得出现硬编码 '500 行'",
      "type": "file_must_not_contain",
      "path": ".cataforge/skills/doc-gen/SKILL.md",
      "patterns": [
        "500 行",
        "500行"
      ]
    },
    {
      "id": "mc-0.1.5-session-context-simplified",
      "release_version": "0.1.5",
      "deprecate_after": "0.2.0",
      "description": "session_context.py 不应再注入 additionalContext；职责简化为仅写 session_start 事件。此检查针对框架源码（dogfood / editable install），用户 site-packages 安装下文件不在 path 中，allow_missing 让该场景通过而非误报",
      "type": "file_must_not_contain",
      "path": "src/cataforge/hook/scripts/session_context.py",
      "patterns": [
        "_detect_pkg_env",
        "additionalContext"
      ],
      "allow_missing": true
    },
    {
      "id": "mc-0.1.5-setup-emit-env",
      "release_version": "0.1.5",
      "deprecate_after": "0.2.0",
      "description": "setup.py 必须提供 --emit-env-block 子命令供 orchestrator Bootstrap 填入 CLAUDE.md §执行环境",
      "type": "file_must_contain",
      "path": ".cataforge/scripts/framework/setup.py",
      "patterns": [
        "--emit-env-block",
        "build_env_block"
      ]
    },
    {
      "id": "mc-0.1.5-detect-correction-registered",
      "release_version": "0.1.5",
      "deprecate_after": "0.2.0",
      "description": "settings.json 必须注册 detect_correction 模块到 AskUserQuestion 匹配器",
      "type": "file_must_contain",
      "path": ".claude/settings.json",
      "patterns": [
        "detect_correction",
        "AskUserQuestion"
      ],
      "requires_deploy": true
    },
    {
      "id": "mc-0.1.9-detect-review-flag-registered",
      "release_version": "0.1.9",
      "description": "settings.json 必须注册 detect_review_flag 模块（review-flag 通路自动化）",
      "type": "file_must_contain",
      "path": ".claude/settings.json",
      "patterns": [
        "detect_review_flag"
      ],
      "requires_deploy": true
    },
    {
      "id": "mc-0.1.5-retro-threshold-relaxed",
      "release_version": "0.1.5",
      "deprecate_after": "0.2.0",
      "description": "RETRO_TRIGGER_SELF_CAUSED 已从 2 放宽至 5 以补偿高频 option-override",
      "type": "file_must_contain",
      "path": ".cataforge/rules/COMMON-RULES.md",
      "patterns": [
        "RETRO_TRIGGER_SELF_CAUSED | 5"
      ]
    },
    {
      "id": "mc-0.1.7-cataforge-dir",
      "release_version": "0.1.7",
      "deprecate_after": "0.2.0",
      "description": ".cataforge/ 目录必须存在且包含核心文件",
      "type": "dir_must_contain_files",
      "path": ".cataforge",
      "patterns": [
        "framework.json",
        "PROJECT-STATE.md",
        "platforms/claude-code/profile.yaml",
        "hooks/hooks.yaml"
      ]
    },
    {
      "id": "mc-0.1.7-override-mechanism",
      "release_version": "0.1.7",
      "deprecate_after": "0.2.0",
      "description": "dispatch-prompt.md 必须包含 OVERRIDE 标记",
      "type": "file_must_contain",
      "path": ".cataforge/skills/agent-dispatch/templates/dispatch-prompt.md",
      "patterns": [
        "OVERRIDE:dispatch_syntax",
        "OVERRIDE:return_format"
      ]
    },
    {
      "id": "mc-0.1.7-capability-ids",
      "release_version": "0.1.7",
      "deprecate_after": "0.2.0",
      "description": "源 AGENT.md 必须使用能力标识符",
      "type": "file_must_not_contain",
      "path": ".cataforge/agents/orchestrator/AGENT.md",
      "patterns": [
        "tools: Read"
      ]
    },
    {
      "id": "mc-0.1.10-event-logger-shim",
      "release_version": "0.1.10",
      "description": "event_logger.py 是 markdown 协议（orchestrator/tdd-engine/doc-gen 等十几处）依赖的路径稳定 shim。删除会让所有 [EVENT] 调用静默 ImportError；shim 自身必须保持 forwarder 形态（导入 cataforge.cli.main:cli），不允许重新内联实现。",
      "type": "file_must_contain",
      "path": ".cataforge/scripts/framework/event_logger.py",
      "patterns": [
        "from cataforge.cli.main import cli",
        "event",
        "log"
      ]
    },
    {
      "id": "mc-0.5.0-kg-config",
      "release_version": "0.5.0",
      "description": "framework.json 必须声明 kg.kg_active_doc_types — 自 0.5.0 起 doc-gen finalize / cataforge docs load / orchestrator Phase Transition 都按此分流；缺失会让所有调用静默走 legacy 路径，掩盖 KG cutover 的覆盖率门。",
      "type": "file_must_contain",
      "path": ".cataforge/framework.json",
      "patterns": [
        "kg_active_doc_types"
      ]
    }
  ]
}

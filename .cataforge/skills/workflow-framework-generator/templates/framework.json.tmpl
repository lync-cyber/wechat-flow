{
  "version": "1.0.0",
  "runtime_api_version": "1.0",
  "runtime": {
    "platform": "{{platform_id}}"
  },
  "description": "{{workflow_name}} - 由 workflow-framework-generator 生成的工作流框架配置。",
  "upgrade": {
    "source": {
      "type": "local",
      "note": "Generated framework — configure remote source if needed"
    },
    "state": {
      "last_commit": "",
      "last_version": "",
      "last_upgrade_date": ""
    }
  },
  "constants": {
    "MAX_QUESTIONS_PER_BATCH": 3,
    "MAX_REVISION_CYCLES": 3
  },
  "kg": {
    "store_backend": "oxigraph",
    "db_path": ".cataforge/kg/store",
    "ontology_namespace": "https://cataforge.dev/ontology/",
    "base_namespace": "https://cataforge.dev/instance/"
  },
  "context": {
    "strategy": "kg-first",
    "kg_active_doc_types": []
  },
  "features": {}
}

id: {{workflow_id}}
name: "{{workflow_name}}"
description: "{{description}}"
version: "1.0"
domain: "{{domain}}"

# Workflow-level configuration
config:
  max_revision_cycles: 3        # Maximum revision loops per phase
  gate_enforcement: strict      # strict | advisory
  state_persistence: filesystem # filesystem | git
  output_base_dir: "docs/"

# Phase definitions
phases:
{{phases}}

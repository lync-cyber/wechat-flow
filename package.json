{
  "name": "wechat-flow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "test:turbo": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck && tsc --noEmit -p tests/tsconfig.json",
    "typecheck:affected": "turbo run typecheck --affected",
    "kg:restore": "node scripts/kg-restore.mjs",
    "prepare": "lefthook install",
    "guard": "pnpm guard:arch && pnpm guard:boundaries",
    "guard:arch": "depcruise --config .dependency-cruiser.cjs apps packages",
    "guard:boundaries": "node scripts/check-module-boundaries.mjs",
    "guard:secrets": "secretlint --maskSecrets --secretlintignore .secretlintignore \"**/*\""
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.9.1",
    "@types/piexifjs": "^1.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "2.1.9",
    "@vue/test-utils": "^2.4.11",
    "dependency-cruiser": "^17.4.3",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.2",
    "hast-util-from-html": "^2.0.3",
    "hast-util-to-html": "^9.0.5",
    "hono": "^4.9.0",
    "jose": "^5.9.0",
    "lefthook": "^2.1.9",
    "piexifjs": "^1.0.6",
    "sharp": "^0.35.0",
    "secretlint": "^13.0.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "vue": "^3.5.0",
    "zod": "^4.0.0"
  }
}

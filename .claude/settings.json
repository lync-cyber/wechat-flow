{
  "permissions": {
    "allow": [
      "Bash(cataforge event log *)",
      "Bash(pnpm verify *)",
      "Bash(cataforge docs load *)",
      "Bash(cataforge docs index *)",
      "Bash(pnpm lint *)",
      "Bash(cataforge doctor *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.guard_dangerous"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.log_agent_dispatch"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.validate_agent_result"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.lint_format"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.detect_correction"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.detect_review_flag"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.notify_done"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.notify_permission"
          }
        ]
      }
    ],
	"env": {
		"ENABLE_LSP_TOOL": "1"
	},
	"enabledPlugins": {
		"typescript-lsp@claude-plugins-official": true
	},
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.session_context"
          }
        ]
      }
    ]
  }
}

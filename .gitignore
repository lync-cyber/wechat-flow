# Claude Code user-local overrides (not shared)
.claude/settings.local.json
.claude/rules

# Node.js (predicted by architecture; safe to predeclare)
node_modules/
dist/
build/
.turbo/
*.log
.pnpm-store/

# Environment / secrets
.env
.env.local
.env.*.local
.env.dev
.env.staging
.env.prod
!.env.example
# .mcp.json 纳入版本控制：仅声明本地自托管 penpot 的 http://localhost MCP 端点，无 token/secret。
# 新增含密钥的 MCP server 时改用 ${ENV_VAR} 引用，勿明文写入此文件。

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# TypeScript build info
*.tsbuildinfo

# Python bytecode cache (CataForge scaffold scripts run locally)
__pycache__/
*.pyc

# Coverage / test artifacts
coverage/
.nyc_output/
playwright-report/
test-results/
.stryker-tmp/
reports/mutation/
perf-report.json

# Headless render output (runtime / test exports)
public/exports/

# design-overlay 前端截图（Playwright 运行时产出，非提交产物）
e2e/visual/design-overlay-output/

# Editor local image-host uploads (runtime artifacts)
apps/editor/public/uploads/

# CataForge upgrade rollback backups (local-only)
.cataforge/.backups/

# CataForge KG: under kg-first the RocksDB store is the committed source of
# truth, so its structural files are tracked; pure-runtime LOG/LOCK/IDENTITY
# are ignored via .cataforge/.gitignore, and NQuads snapshots stay versioned.
# The RocksDB WAL is structural — re-include it past the top-level *.log rule.
!.cataforge/kg/store/*.log
docs/.kg-reconcile-report.json

# Claude Code user-local overrides (not shared)
.claude/settings.local.json
.claude/rules

# Node.js (predicted by architecture; safe to predeclare)
node_modules/
dist/
build/
.turbo/
*.log
.pnpm-store/

# Environment / secrets
.env
.env.local
.env.*.local
.mcp.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# TypeScript build info
*.tsbuildinfo

# Python bytecode cache (CataForge scaffold scripts run locally)
__pycache__/
*.pyc

# Coverage / test artifacts
coverage/
.nyc_output/
playwright-report/
test-results/

# CataForge upgrade rollback backups (local-only)
.cataforge/.backups/

# CataForge KG: ignore the binary RocksDB working store (rebuildable from
# committed markdown / snapshots); keep the NQuads snapshots versioned so a
# fresh clone restores via `cataforge kg rollback` without re-parsing docs
.cataforge/kg/store/
docs/.kg-reconcile-report.json

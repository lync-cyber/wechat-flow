{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "inputs": ["src/**", "*.ts", "*.tsx", "biome.json", ".eslintrc*", "package.json"]
    },
    "typecheck": {
      "dependsOn": ["lint", "^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "test": {
      "dependsOn": ["typecheck", "^build"],
      "inputs": ["src/**", "tests/**", "vitest.config*", "package.json"],
      "outputs": ["coverage/**"]
    },
    "unit-test": {
      "dependsOn": ["typecheck", "^build"],
      "inputs": ["src/**", "tests/**", "vitest.config*", "package.json"],
      "outputs": ["coverage/**"]
    },
    "ruleset-fixture": {
      "dependsOn": ["unit-test"],
      "inputs": ["src/**", "fixtures/**", "package.json"],
      "outputs": ["dist/fixtures/**"]
    },
    "cross-runtime": {
      "dependsOn": ["ruleset-fixture"],
      "inputs": ["src/**", "package.json"]
    },
    "theme-guard": {
      "dependsOn": ["cross-runtime"],
      "inputs": ["src/**", "themes/**", "package.json"]
    },
    "visual-regression": {
      "dependsOn": ["theme-guard"],
      "inputs": ["src/**", "stories/**", "*.config.*", "package.json"],
      "outputs": ["__snapshots__/**"]
    }
  }
}

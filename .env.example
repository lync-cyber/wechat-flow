# Template only — copy to .env.dev / .env.staging / .env.prod and fill real values.
# Never commit a file with real secrets. See deploy-spec-wechat-flow.md §2 for the
# per-environment matrix and §6 for the secrets inventory.

# --- Relay (apps/relay) ---
PORT=8787
REDIS_URL=redis://127.0.0.1:6379
EDITOR_JWT_SECRET=
EDITOR_ALLOWED_ORIGINS=http://localhost:5173
API_KEY_PEPPER=

# Image host adapter selection (apps/relay/src/credentials/store.ts)
IMAGE_HOST=local
LOCAL_BASE_DIR=./data/uploads
LOCAL_PUBLIC_BASE_URL=http://localhost:8787/uploads
# QINIU_ACCESS_KEY=
# QINIU_SECRET_KEY=
# QINIU_BUCKET=
# QINIU_DOMAIN=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_REGION=
# OSS_DOMAIN=
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=
# COS_DOMAIN=
# SMMS_TOKEN=
# CUSTOM_UPLOAD_ENDPOINT=
# CUSTOM_UPLOAD_TOKEN=
# CUSTOM_RESPONSE_URL_FIELD=

# --- Job Worker (apps/job-worker) ---
RENDER_POOL_SIZE=2
# Lazily loaded only when a wechat-asset-upload job runs; absent = that job kind fails at runtime, other kinds unaffected.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- MCP server (apps/mcp-server, stdio local launch) ---
WECHAT_FLOW_MCP_API_KEY=

# --- Editor SPA build-time (apps/editor, Vite import.meta.env, VITE_ prefix required) ---
VITE_RELAY_BASE_URL=http://localhost:8787
